    # Redirect stdout to the file
    with open(get_current_function_name() + ""_current"", ""w"") as f:
        sys.stdout = f
        expected = open(get_current_function_name() + ""_expected"").read()

        para = ""������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������������""
        
        # Discover new words
        new_words_info = ht.word_discover(para)
        new_words = new_words_info.index.tolist()
        print(new_words)

    # Assert correctness of the output
    with open(get_current_function_name() + ""_current"") as f_current, open(get_current_function_name() + ""_expected"") as f_expected:
        assert f_current.read() == f_expected.read()
